package com.example.sbsample.controller;

import com.example.demo.dto.UserMasterFormDTO;
import com.example.demo.entity.User; // お使いのエンティティ
import com.example.demo.service.UserService; // お使いのサービス層
import jakarta.validation.Valid;
import lombok.RequiredArgsConstructor;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/users")
@RequiredArgsConstructor // 各種Serviceのコンストラクタインジェクションを自動化 (Lombok)
// @CrossOrigin(origins = "http://localhost:5173") // VueのVite開発サーバーからのCORS許可（必要な場合）
public class UserEditFormController {

    private final UserService userService;

    /**
     * 1. 編集用データの取得 (UserMaster.vueのonMounted時に呼ばれる)
     * GET /api/users/{id}
     */
    @GetMapping("/{id}")
    public ResponseEntity<User> getUserById(@PathVariable Long id) {
        User user = userService.findById(id);
        return ResponseEntity.ok(user);
    }

    /**
     * 2. 新規登録 (UserMasterForm.vueの保存ボタン：新規時)
     * POST /api/users
     */
    @PostMapping
    public ResponseEntity<String> createUser(@Valid @RequestBody UserMasterFormDTO userMasterFormDTO) {
        userService.createUser(userMasterFormDTO);
        return ResponseEntity.status(HttpStatus.CREATED).body("ユーザーを新規登録しました");
    }

    /**
     * 3. 更新処理 (UserMaster.vueの保存ボタン：編集時)
     * PUT /api/users/{id}
     */
    @PutMapping("/{id}")
    public ResponseEntity<String> updateUser(
            @PathVariable Long id, 
            @Valid @RequestBody UserMasterFormDTO userMasterFormDTO) {
        
        userService.updateUser(id, userMasterFormDTO);
        return ResponseEntity.ok("ユーザー情報を更新しました");
    }
}